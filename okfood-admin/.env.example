# 生产构建填写完整后端根地址（无末尾 /）；开发可留空走 Vite 代理 /api
# VITE_API_BASE_URL=https://ok.sourcefire.cn

# 开发代理目标（npm run dev），转发 /api → 该地址下的 /api/...（须与后端一致，勿用无 API 的站点根域）
# 本地后端：http://127.0.0.1:8001 ；线上 API 示例：https://api.ok.sourcefire.cn
# VITE_PROXY_TARGET=http://127.0.0.1:8001

# 可选：仅开发机预填登录框（勿提交含真实密码的 .env.local）
# VITE_ADMIN_LOGIN_PRESET_USER=admin
# VITE_ADMIN_LOGIN_PRESET_PASSWORD=your-dev-password

# 高德 JS API 2.0（配送区域地图绘制；Web Key 须配安全密钥与域名白名单）
# VITE_AMAP_KEY=
# VITE_AMAP_SECURITY_CODE=
