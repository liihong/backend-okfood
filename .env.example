# 复制为 .env 后修改。勿将真实密码提交到仓库。
# 默认与另一服务错开端口：uvicorn app.main:app --host 0.0.0.0 --port 8001
APP_NAME=meal-delivery-api
DEBUG=false

# 对外访问根地址（无尾部 /）。上传图片写入库的 image_url 会拼成绝对地址；本地可留空则存相对路径 /static/...
# BASE_URL=https://api.example.com

# MySQL（分项配置；代码内组装连接 URL，密码可含 @ 等特殊字符）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=meal_delivery
MYSQL_CHARSET=utf8mb4

# JWT（生产环境请使用足够长的随机串；DEBUG=false 时禁止使用默认值/空值且长度须>=16）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES_MEMBER=10080
# 小程序手机号登录 POST /api/user/wx/mini/login 签发令牌（分钟）；默认约 10 年，可按安全策略改短
JWT_EXPIRE_MINUTES_MEMBER_WX_MINI=5256000
JWT_EXPIRE_MINUTES_COURIER=43200
JWT_EXPIRE_MINUTES_ADMIN=1440

# CORS：逗号分隔的 Origin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 高德 Web 服务 Key（地理编码）：https://console.amap.com 须选「Web服务」类型 Key，否则 REST 报 USERKEY_PLAT_NOMATCH。
# 留空则跳过地理编码，片区依赖手工指定。
AMAP_KEY=

# 短信：false 时不校验通道、不跑验证码清理任务、短信接口返回 503
SMS_ENABLED=false

# 短信：webhook=POST 到自建网关；aliyun=阿里云短信（需完整 AK/SK/签名/模板）
SMS_PROVIDER=webhook
SMS_CODE_TTL_MINUTES=5
SMS_WEBHOOK_URL=https://your-backend.example/api/sms/login-code
SMS_WEBHOOK_TOKEN=

# 若 SMS_PROVIDER=aliyun，填写以下项（并注释或删除 webhook 专属项亦可保留空）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=
# ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# 低余额阈值（与定时任务扫描一致）
LOW_BALANCE_THRESHOLD=2

# 微信小程序（会员端手机号一键登录：POST /api/user/wx/mini/login）
# 未配置或留空时，该接口返回 503
WX_MINI_APPID=
WX_MINI_SECRET=
