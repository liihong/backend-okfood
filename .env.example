# 复制为 .env 后修改。勿将真实密码提交到仓库。
# 默认与另一服务错开端口：uvicorn app.main:app --host 0.0.0.0 --port 8001
APP_NAME=meal-delivery-api
DEBUG=false

# 对外访问根地址（无尾部 /）。上传图片写入库的 image_url 会拼成绝对地址；本地可留空则存相对路径 /static/...
# BASE_URL=https://api.example.com

# MySQL（分项配置；代码内组装连接 URL，密码可含 @ 等特殊字符）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=meal_delivery
MYSQL_CHARSET=utf8mb4

# JWT（生产环境请使用足够长的随机串；DEBUG=false 时禁止使用默认值/空值且长度须>=16）
JWT_SECRET=change-me-to-a-long-random-string
# 会员 JWT（小程序登录 POST /api/user/wx/mini/login）；分钟数，默认约 10 年
JWT_EXPIRE_MINUTES_MEMBER=5256000
JWT_EXPIRE_MINUTES_COURIER=43200
JWT_EXPIRE_MINUTES_ADMIN=1440

# CORS：逗号分隔的 Origin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 高德 Web 服务 Key（地理编码）：https://console.amap.com 须选「Web服务」类型 Key，否则 REST 报 USERKEY_PLAT_NOMATCH。
# 留空则跳过地理编码，片区依赖手工指定。
AMAP_KEY=

# 低余额阈值（与定时任务扫描一致）
LOW_BALANCE_THRESHOLD=2

# 骑手配送费（元）：确认送达写入 couriers.fee_pending；首份基础价 + 同地址每多一份加价
# COURIER_DELIVERY_BASE_YUAN=4.00
# COURIER_DELIVERY_EXTRA_PER_UNIT_YUAN=1.00

# 微信小程序（会员端手机号一键登录：POST /api/user/wx/mini/login）
# 未配置或留空时，该接口返回 503
# 须与 WECHAT_PAY_MCH_ID 在同一微信商户主体下完成「小程序支付」关联，否则统一下单报 appid 与 mch_id 不匹配
WX_MINI_APPID=
WX_MINI_SECRET=
# 配送员确认送达后给会员发订阅消息：公众平台 → 功能 → 订阅消息 → 选用模板，把模板 ID 填到此处；须与小程序内 requestSubscribeMessage 的 tmplId 一致
# WX_MINI_SUBSCRIBE_DELIVERY_TMPL_ID=
# 与模板里字段 id 一致（thing1、time2 等），逗号分隔，顺序：摘要、时间、说明
# WX_MINI_SUBSCRIBE_DELIVERY_DATA_KEYS=thing1,time2,thing3
# WX_MINI_SUBSCRIBE_PAGE=pages/order/index
# WX_MINI_SUBSCRIBE_MINIPROGRAM_STATE=formal

# 微信支付 v2（小程序单次点餐 JSAPI）：API密钥为 32 位；回调 URL 须与商户平台一致且公网可达
# 须与上方 WX_MINI_APPID 对应小程序在商户平台已绑定
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# WECHAT_PAY_NOTIFY_URL=https://你的域名/api/pay/wechat/notify
# 回调 IP 白名单（逗号分隔 CIDR）；留空则不校验 IP（仅建议本地调试）
# WECHAT_PAY_IP_WHITELIST=182.254.48.0/24,140.207.54.0/24,101.226.103.0/24,121.51.58.0/24

# 对象存储（会员头像 POST /api/user/me/avatar）：OSS_PROVIDER=aliyun 且下列 AK/SK/桶/端点齐全时走 OSS，否则写入本地 UPLOAD_DIR
# OSS_PROVIDER=local
# OSS_PROVIDER=aliyun
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# OSS_REGION=cn-shanghai
# 自定义访问域名（可选，无尾部 /）；也可用 OSS_PUBLIC_BASE_URL，二者取先非空者
# OSS_DOMAIN=https://cdn.example.com
# 对象键前缀（可选）
# OSS_KEY_PREFIX=okfood

# 顺丰同城开放平台（管理端「顺丰推单」createorder；回调 URL 见下方）
# SF_OPEN_DEV_ID=
# SF_OPEN_SHOP_ID=
# SF_OPEN_SECRET=
# SF_OPEN_SHOP_TYPE=1   # 仅 1 或 2：1=顺丰门店ID(常用)；2=自维护ID(须已报备)。SF_OPEN_SHOP_ID 须与开放平台「店铺」一致
# SF_API_BASE=https://openic.sf-express.com
# SF_ORDER_SOURCE=OKFOOD
# SF_API_VERSION=17
# SF_PICKUP_PHONE=
# SF_PICKUP_ADDRESS=
# SF_CITY_NAME=上海市
# SF_KG_PER_MEAL_UNIT=0.2
# SF_DEFAULT_PRODUCT_TYPE=1
# SF_PRODUCT_CATEGORY_LABEL=外韵落地配
# SF_DEFAULT_VEHICLE_TYPE=小轿车
# 仅本地联调：跳过顺丰 HTTP 推送验签（生产勿开）。若蜂巢一直显示不通过且日志 sign_in_query=False，先查网关是否丢掉 ?sign=
# SF_CALLBACK_SKIP_SIGN_VERIFY=false
#
# 顺丰开放平台填写的回调（与蜂巢控制台一致；前缀换为 BASE，须 HTTPS）
# BASE/api/sf/callback/delivery-status
# BASE/api/sf/callback/order-completed
# BASE/api/sf/callback/cancel-by-sf
# BASE/api/sf/callback/delivery-exception
# BASE/api/sf/callback/rider-cancel
# BASE/api/sf/callback/auto-shop
# BASE/api/sf/oauth/callback                    授权 (GET/POST)
# BASE/api/sf/oauth/revoke                     取消授权 (GET/POST)
